  "html": [
    "<svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="1">
<h1 id="nested-lists">Nested lists</h1>
<ul>
<li>top
<ul>
<li>mid
<ul>
<li>bottom</li>
</ul>
</li>
</ul>
</li>
<li>another
<ol>
<li>ordered</li>
<li>items</li>
</ol>
</li>
</ul>
</section>
</foreignObject></svg>",
    "<svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="2">
<h1 id="tasks">Tasks</h1>
<ul>
<li>[ ] todo</li>
<li>[x] done</li>
<li>[ ] tomorrow</li>
</ul>
</section>
</foreignObject></svg>",
  ],
}
`;

