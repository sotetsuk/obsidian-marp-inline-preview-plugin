",
  "html": [
    "<svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="1">
<h1 id="basic-deck">Basic deck</h1>
<p>Hello, <strong>Marp</strong>. This deck has <em>italic</em>, <strong>bold</strong>, and <code>inline code</code>.</p>
<ul>
<li>one</li>
<li>two</li>
<li>three</li>
</ul>
</section>
</foreignObject></svg>",
    "<svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="2">
<h2 id="slide-2">Slide 2</h2>
<p>A paragraph with a <a href="https://example.com">link</a>.</p>
<blockquote>
<p>blockquote with multiple<br />
lines</p>
</blockquote>
</section>
</foreignObject></svg>",
    "<svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="3">
<h2 id="slide-3">Slide 3</h2>
<p>Final slide.</p>
</section>
</foreignObject></svg>",
  ],
}
`;

