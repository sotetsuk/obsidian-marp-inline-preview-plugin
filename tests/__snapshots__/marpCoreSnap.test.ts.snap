",
  "html": [
    "<svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="1">
<h1 id="code-blocks">Code blocks</h1>
<pre is="marp-pre" data-auto-scaling="downscale-only"><code class="language-ts"><span class="hljs-keyword">const</span> <span class="hljs-attr">x</span>: <span class="hljs-built_in">number</span> = <span class="hljs-number">42</span>;
<span class="hljs-variable language_">console</span>.<span class="hljs-title function_">log</span>(x);
</code></pre>
</section>
</foreignObject></svg>",
    "<svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="2">
<h1 id="yaml-and-a-----inside-a-fence-must-not-split">YAML and a <code>---</code> inside a fence (must not split)</h1>
<pre is="marp-pre" data-auto-scaling="downscale-only"><code class="language-yaml"><span class="hljs-attr">key:</span> <span class="hljs-string">value</span>
<span class="hljs-meta">---</span>
<span class="hljs-attr">nested:</span> <span class="hljs-string">another</span> <span class="hljs-string">doc</span>
</code></pre>
<p>After the fence, regular content.</p>
</section>
</foreignObject></svg>",
  ],
}
`;

