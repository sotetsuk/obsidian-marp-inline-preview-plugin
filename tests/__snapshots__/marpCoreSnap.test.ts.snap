",
  "html": [
    "<svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="1" data-theme="gaia" style="--theme:gaia;">
<h1 id="themed-deck">Themed deck</h1>
<p>Uses Marp's built-in Gaia theme.</p>
</section>
</foreignObject></svg>",
    "<svg data-marpit-svg="" viewBox="0 0 1280 720"><foreignObject width="1280" height="720"><section id="2" data-theme="gaia" style="--theme:gaia;">
<h2 id="page-two">Page two</h2>
<ul>
<li>gaia</li>
<li>swaps</li>
<li>defaults</li>
</ul>
</section>
</foreignObject></svg>",
  ],
}
`;
