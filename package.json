{
  "name": "marp-inline-preview",
  "version": "0.3.0",
  "description": "Obsidian plugin: inline Marp slide preview in edit and reading modes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bundle": "node scripts/check-bundle.mjs",
    "test:e2e": "wdio run ./wdio.conf.mts",
    "check:types": "tsc --noEmit -skipLibCheck",
    "check:types:e2e": "tsc --noEmit -p tsconfig.e2e.json",
    "ci": "npm run check:types && npm run build && npm run test && npm run test:bundle",
    "link-vault": "node scripts/link-test-vault.mjs",
    "dev:vault": "npm run link-vault && npm run dev",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "marp",
    "slides",
    "presentation"
  ],
  "author": "Sotetsu Koyamada",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "builtin-modules": "^4.0.0",
    "es-check": "9.6.4",
    "esbuild": "^0.20.0",
    "happy-dom": "20.9.0",
    "obsidian": "^1.5.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0",
    "wdio-obsidian-service": "^3.0.2",
    "webdriverio": "^9.27.1"
  },
  "dependencies": {
    "@marp-team/marp-core": "4.3.0",
    "js-yaml": "^4.1.0"
  }
}
